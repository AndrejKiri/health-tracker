# Copy to .env and fill in passwords before first run.
# .env is gitignored and will never be committed.

# PostgreSQL
POSTGRES_DB=health_tracker
POSTGRES_USER=health
POSTGRES_PASSWORD=change_me_strong_password

# Grafana
GRAFANA_ADMIN_PASSWORD=change_me_strong_password

# Ollama model
OLLAMA_MODEL=qwen2.5:1.5b

# Native macOS settings.
# These override the Docker-era defaults in extractor/config.py.
# Remove this section if using full Docker (docker-compose.yml sets them automatically).
OLLAMA_URL=http://localhost:11434
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DB_INIT_SQL_PATH=./db/init.sql
WATCH_DIR=./data/inbox
PROCESSED_DIR=./data/processed
FAILED_DIR=./data/failed
