  },
  "description": "Detail view for a single lab metric \u2014 description, full history, and reference range.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    {
      "icon": "dashboard",
      "title": "\u2190 Lab Results Overview",
      "type": "link",
