  "description": "Component showcase \u2014 Lipid Panel table with sparklines + cardiovascular timeseries.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "icon": "dashboard",
      "title": "\u2190 Lab Results Overview",
      "type": "link",
