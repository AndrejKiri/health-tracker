          "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgres" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT s.time,\n    MAX(s.value) FILTER (WHERE s.metric = 'Glucose') AS \"Glucose\",\n    MAX(s.value) FILTER (WHERE s.metric = 'BUN') AS \"BUN\",\n    MAX(s.value) FILTER (WHERE s.metric = 'Creatinine') AS \"Creatinine\",\n    MAX(s.value) FILTER (WHERE s.metric = 'Sodium') AS \"Sodium\",\n    MAX(s.value) FILTER (WHERE s.metric = 'Potassium') AS \"Potassium\"\nFROM samples s\nWHERE s.metric IN ('Glucose', 'BUN', 'Creatinine', 'Sodium', 'Potassium')\n  AND $__timeFilter(s.time)\n  AND s.value IS NOT NULL\nGROUP BY s.time ORDER BY s.time",
          "refId": "A",
          "editorMode": "code"
        }
