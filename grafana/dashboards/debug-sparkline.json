  "panels": [
    {
      "id": 1,
      "title": "Reference: Timeseries Panel (Glucose)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 10 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgres" },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgres" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT s.time, s.value AS \"Glucose\" FROM samples s WHERE s.metric = 'Glucose' AND $__timeFilter(s.time) ORDER BY s.time",
          "refId": "A",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 6,
            "showPoints": "always",
            "thresholdsStyle": { "mode": "area" }
          },
          "unit": "mg/dL",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 70 },
              { "color": "red", "value": 100 }
            ]
          },
          "color": { "mode": "palette-classic" },
          "min": 30
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["last", "min", "max"]
        }
      }
    },
    {
      "id": 2,
      "title": "SQL Array Method: Metabolic Panel (sparkline table)",
      "description": "Bypasses timeSeriesTable entirely. Uses array_to_json(array_agg()) in SQL to build sparkline arrays, then convertFieldType to render them.",
      "type": "table",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 10 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgres" },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgres" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    m.name AS \"Name\",\n    m.unit AS \"Unit\",\n    COALESCE(\n      (SELECT array_to_json(array_agg(s2.value ORDER BY s2.time))\n       FROM samples s2\n       WHERE s2.metric = m.name\n         AND $__timeFilter(s2.time)),\n      '[]'\n    ) AS \"Trend\",\n    (SELECT s3.value\n     FROM samples s3\n     WHERE s3.metric = m.name\n     ORDER BY s3.time DESC\n     LIMIT 1) AS \"Last\",\n    rr.ref_low AS \"Ref Low\",\n    rr.ref_high AS \"Ref High\"\nFROM metrics m\nLEFT JOIN reference_ranges rr\n    ON rr.metric = m.name\n    AND rr.range_type = 'standard'\n    AND rr.sex IS NULL\nWHERE m.category = 'Metabolic Panel'\nORDER BY m.sort_order",
          "refId": "A",
          "editorMode": "code"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              { "targetField": "Trend", "destinationType": "other" }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "cellOptions": { "type": "auto" },
            "align": "auto"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Trend" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "sparkline",
                  "drawStyle": "line",
                  "lineWidth": 1,
                  "fillOpacity": 15,
                  "pointSize": 3,
                  "showPoints": "always"
                }
              },
              { "id": "custom.width", "value": 300 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Name" },
            "properties": [
              { "id": "custom.width", "value": 200 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Unit" },
            "properties": [
              { "id": "custom.width", "value": 80 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "md",
        "footer": { "show": false }
      }
    },
    {
      "id": 3,
      "title": "SQL Array Method: Complete Blood Count (sparkline table)",
      "description": "Second category to verify the approach scales across different metric types.",
      "type": "table",
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 14 },
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgres" },
      "targets": [
        {
          "datasource": { "type": "grafana-postgresql-datasource", "uid": "postgres" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    m.name AS \"Name\",\n    m.unit AS \"Unit\",\n    COALESCE(\n      (SELECT array_to_json(array_agg(s2.value ORDER BY s2.time))\n       FROM samples s2\n       WHERE s2.metric = m.name\n         AND $__timeFilter(s2.time)),\n      '[]'\n    ) AS \"Trend\",\n    (SELECT s3.value\n     FROM samples s3\n     WHERE s3.metric = m.name\n     ORDER BY s3.time DESC\n     LIMIT 1) AS \"Last\",\n    rr.ref_low AS \"Ref Low\",\n    rr.ref_high AS \"Ref High\"\nFROM metrics m\nLEFT JOIN reference_ranges rr\n    ON rr.metric = m.name\n    AND rr.range_type = 'standard'\n    AND rr.sex IS NULL\nWHERE m.category = 'Complete Blood Count'\nORDER BY m.sort_order",
          "refId": "A",
          "editorMode": "code"
        }
      ],
      "transformations": [
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [
              { "targetField": "Trend", "destinationType": "other" }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "cellOptions": { "type": "auto" },
            "align": "auto"
          },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Trend" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "sparkline",
                  "drawStyle": "line",
                  "lineWidth": 1,
                  "fillOpacity": 15,
                  "pointSize": 3,
                  "showPoints": "always"
                }
              },
              { "id": "custom.width", "value": 300 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Name" },
            "properties": [
              { "id": "custom.width", "value": 200 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Unit" },
            "properties": [
